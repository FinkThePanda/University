      "isDeleted": false,
      "boundElements": [],
      "updated": 1780574617163,
      "link": null,
      "locked": false,
      "text": "Top trust anchorCAThe top-level trusted \ncertificate authority.It is self-signed \nand acts as the trust anchor.",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Top trust anchorCAThe top-level trusted \ncertificate authority.It is self-signed \nand acts as the trust anchor.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "1RMRTRewwEZ_VBX2PpH9H",
      "type": "text",
      "x": 3914.624146768145,
      "y": -165.79176375308816,
      "width": 831.5994873046875,
      "height": 135,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffffff",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0J",
      "roundness": null,
      "seed": 1761653430,
      "version": 406,
      "versionNonce": 137373738,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1780574617163,
      "link": null,
      "locked": false,
      "text": "A CA below the root CA. It receives trust \nfrom the root and passes it down in \nthe chain.",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "A CA below the root CA. It receives trust \nfrom the root and passes it down in \nthe chain.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "4u1lz8AQDXSfpPsef-sH4",
      "type": "text",
      "x": 3929.829167138957,
      "y": 140.51575213851265,
      "width": 791.99951171875,
      "height": 135,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffffff",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0K",
      "roundness": null,
      "seed": 1728375798,
      "version": 441,
      "versionNonce": 688755434,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1780574617163,
      "link": null,
      "locked": false,
      "text": "The CA that directly signs certificates \nfor websites, users, or devices. It is \noften the lowest CA in the hierarchy.",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The CA that directly signs certificates \nfor websites, users, or devices. It is \noften the lowest CA in the hierarchy.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "r9P72XBONbUcVgphm_SJh",
      "type": "text",
      "x": 3926.78805169922,
      "y": 494.7948427243755,
      "width": 831.5994873046875,
      "height": 135,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffffff",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0L",
      "roundness": null,
      "seed": 581958966,
      "version": 502,
      "versionNonce": 141534634,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1780574617163,
      "link": null,
      "locked": false,
      "text": "The end certificate used by the website \nor service. It proves the site’s identity \nand contains its public key.",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The end certificate used by the website \nor service. It proves the site’s identity \nand contains its public key.",
      "autoResize": true,
      "lineHeight": 1.25
    },
